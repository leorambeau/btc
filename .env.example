# ─── Credentials Polymarket ────────────────────────────────────────────────
# Générer via : https://docs.polymarket.com/#authentication
# (Section "API Keys" dans votre compte Polymarket)

POLY_API_KEY=votre_api_key_ici
POLY_SECRET=votre_secret_ici
POLY_PASSPHRASE=votre_passphrase_ici

# Clé privée du wallet Polygon (pour signature EIP-712)
# ATTENTION : ne jamais committer ce fichier dans git !
POLY_PRIVATE_KEY=0xvotre_cle_privee_ici
POLY_WALLET_ADDR=0xvotre_adresse_wallet_ici

# ─── Optionnel ─────────────────────────────────────────────────────────────
# Mode gas : "relayer" (gratuit, défaut) ou "self" (POL du wallet)
GAS_MODE=relayer
